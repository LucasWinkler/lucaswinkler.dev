---
import { navItems, siteName } from '@/data/nav';
---

<header
  id='site-header'
  class='site-header type-ui fixed z-50 px-(--section-padding-x)'
  data-scrolled='false'>
  <div class='site-header__bar'>
    <div class='site-header__inner mx-auto flex max-w-full min-h-(--header-inner-min-h) items-center justify-between'>
      <a
        href='/'
        class='site-header__brand shrink-0 px-3 py-2 -mx-1 text-sm font-semibold tracking-[-0.02em] transition-[color,opacity] duration-300 ease-out hover:opacity-80'>
        {siteName}
      </a>

      <nav aria-label='Primary' class='site-header__nav shrink-0'>
        <ul class='m-0 flex shrink-0 list-none items-center gap-0.5 p-0'>
          {
            navItems.map(item => (
              <li class='shrink-0'>
                <a
                  href={item.href}
                  class='site-header__link px-3.5 py-2 text-sm font-medium tracking-[-0.01em] transition-[color,opacity,transform,background-color] duration-300 ease-out active:scale-[0.96]'>
                  {item.label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>
    </div>
  </div>
</header>

<script>
  const header = document.getElementById('site-header');
  const heroPanel = document.querySelector('#hero .hero-panel');
  const headerInner = header?.querySelector('.site-header__inner');
  const headerBrand = header?.querySelector('.site-header__brand');
  const headerNav = header?.querySelector('.site-header__nav');

  if (header && heroPanel && headerInner && headerBrand && headerNav) {
    let ticking = false;

    const readPaddingTop = (scrolled: 'true' | 'false') => {
      header.dataset.scrolled = scrolled;
      return parseFloat(getComputedStyle(header).paddingTop) || 0;
    };

    const syncStickyBarWidth = () => {
      const rootStyles = getComputedStyle(document.documentElement);
      const padX =
        parseFloat(rootStyles.getPropertyValue('--header-bar-padding-x')) * 2 ||
        32;
      const bezel = 6;
      const gap = parseFloat(getComputedStyle(headerInner).columnGap) || 0;
      const contentWidth = Math.ceil(
        headerBrand.getBoundingClientRect().width +
          headerNav.getBoundingClientRect().width +
          gap +
          padX +
          bezel,
      );

      header.style.setProperty(
        '--header-bar-max-sticky',
        `${contentWidth}px`,
      );
    };

    let pinThreshold = readPaddingTop('false') - readPaddingTop('true');
    header.dataset.scrolled = 'false';

    const syncHeader = () => {
      const rect = heroPanel.getBoundingClientRect();
      const pinned = rect.top <= -pinThreshold;

      header.dataset.scrolled = pinned ? 'true' : 'false';

      if (pinned) {
        header.style.removeProperty('top');
        header.style.removeProperty('left');
        header.style.removeProperty('width');
      } else {
        header.style.top = `${rect.top}px`;
        header.style.left = `${rect.left}px`;
        header.style.width = `${rect.width}px`;
      }
    };

    const onScroll = () => {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(() => {
        syncHeader();
        ticking = false;
      });
    };

    syncStickyBarWidth();
    syncHeader();

    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('resize', () => {
      syncStickyBarWidth();
      pinThreshold = readPaddingTop('false') - readPaddingTop('true');
      header.dataset.scrolled = 'false';
      syncHeader();
    }, { passive: true });

    if (document.fonts) {
      document.fonts.ready.then(syncStickyBarWidth);
    }
  }
</script>

<style>
  .site-header {
    padding-top: max(0.625rem, env(safe-area-inset-top));
    padding-bottom: 0.5rem;
    transition-property: padding-top;
    transition-duration: 580ms;
    transition-timing-function: var(--ease-out);
  }

  .site-header__bar {
    margin-inline: auto;
    max-width: var(--header-bar-max);
    border-radius: 0;
    background-color: transparent;
    box-shadow: none;
    padding-inline: 0;
    padding-block: 0;
    overflow: hidden;
    transition-property: max-width, background-color, box-shadow, padding-inline, padding-block, border-radius;
    transition-duration: 580ms;
    transition-timing-function: var(--ease-out);
  }

  .site-header__inner {
    gap: clamp(1.5rem, 4vw, 3rem);
    border-radius: 0;
    background-color: transparent;
    box-shadow: none;
    padding-inline: 0;
    padding-block: 0;
    transition-property: background-color, box-shadow, padding-inline, padding-block, border-radius;
    transition-duration: 580ms;
    transition-timing-function: var(--ease-out);
  }

  .site-header__brand,
  .site-header__link {
    white-space: nowrap;
  }

  .site-header__link {
    border-radius: var(--header-link-radius);
  }

  .site-header[data-scrolled='false'] {
    padding-top: max(1.5rem, calc(env(safe-area-inset-top) + 0.75rem));
  }

  .site-header[data-scrolled='false'] .site-header__brand {
    color: var(--color-hero-text);
  }

  .site-header[data-scrolled='false'] .site-header__link {
    color: var(--color-hero-text-muted);
  }

  .site-header[data-scrolled='false'] .site-header__link:hover {
    color: var(--color-hero-text);
  }

  .site-header[data-scrolled='true'] {
    inset-inline: 0;
    top: 0;
    padding-top: max(0.625rem, calc(env(safe-area-inset-top) + 0.375rem));
  }

  .site-header[data-scrolled='true'] .site-header__bar {
    max-width: min(var(--header-bar-max-sticky), calc(100% - 2rem));
    border-radius: 9999px;
    background-color: var(--header-glass-bg);
    box-shadow:
      0 0 0 1px var(--header-glass-border),
      0 8px 32px -8px var(--header-glass-shadow),
      0 2px 12px -4px rgba(61, 90, 69, 0.08);
    padding: 3px;
    backdrop-filter: blur(20px) saturate(1.55);
    -webkit-backdrop-filter: blur(20px) saturate(1.55);
  }

  .site-header[data-scrolled='true'] .site-header__inner {
    border-radius: 9999px;
    background-color: color-mix(in srgb, var(--color-surface) 94%, rgb(160 196 214) 6%);
    box-shadow:
      inset 0 1px 0 color-mix(in srgb, rgba(255, 255, 255, 0.78) 70%, var(--header-glass-highlight) 30%);
    padding-inline: var(--header-bar-padding-x);
    padding-block: var(--header-bar-padding-y);
  }

  .site-header[data-scrolled='true'] .site-header__brand {
    color: var(--color-text);
  }

  .site-header[data-scrolled='true'] .site-header__link {
    color: var(--color-text-muted);
  }

  .site-header[data-scrolled='true'] .site-header__link:hover {
    color: var(--color-text);
    background-color: rgba(18, 17, 16, 0.05);
  }

  @media (prefers-reduced-motion: reduce) {
    .site-header,
    .site-header__bar,
    .site-header__inner {
      transition-duration: 0.01ms;
    }
  }
</style>
