---
import { getImage } from 'astro:assets';

import { locale, ogImageAlt, siteName, twitterHandle } from '@/data/site';
import { buildProfileSchema } from '@/lib/schema';
import ogImageSrc from '@/assets/images/og.png';
import { OG_IMAGE_QUALITY } from '@/config/image';

interface Props {
  title: string;
  description: string;
  canonicalPath?: string;
  includeSchema?: boolean;
}

const { title, description, canonicalPath = Astro.url.pathname, includeSchema = true } = Astro.props;
const canonical = new URL(canonicalPath, Astro.site);

const ogImageAsset = await getImage({
  src: ogImageSrc,
  format: 'jpeg',
  width: 1200,
  height: 630,
  fit: 'cover',
  quality: OG_IMAGE_QUALITY,
});

const ogImage = new URL(ogImageAsset.src, Astro.site);
const ogImageWidth = ogImageAsset.attributes.width ?? 1200;
const ogImageHeight = ogImageAsset.attributes.height ?? 630;

const schema = includeSchema
  ? buildProfileSchema({
      title,
      description,
      canonicalUrl: canonical.href,
      ogImageUrl: ogImage.href,
    })
  : null;
---

<link rel='canonical' href={canonical.href} />
<meta property='og:type' content='website' />
<meta property='og:url' content={canonical.href} />
<meta property='og:site_name' content={siteName} />
<meta property='og:locale' content={locale} />
<meta property='og:title' content={title} />
<meta property='og:description' content={description} />
<meta property='og:image' content={ogImage.href} />
<meta property='og:image:width' content={String(ogImageWidth)} />
<meta property='og:image:height' content={String(ogImageHeight)} />
<meta property='og:image:alt' content={ogImageAlt} />
<meta property='og:image:type' content='image/jpeg' />
<meta name='twitter:card' content='summary_large_image' />
<meta name='twitter:site' content={`@${twitterHandle}`} />
<meta name='twitter:creator' content={`@${twitterHandle}`} />
<meta name='twitter:title' content={title} />
<meta name='twitter:description' content={description} />
<meta name='twitter:image' content={ogImage.href} />
{schema ? <script is:inline type='application/ld+json' set:html={JSON.stringify(schema)} /> : null}
