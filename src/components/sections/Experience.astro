---
import { MotionExperienceList } from '@/components/widgets/MotionExperienceList';
import { MotionSectionIntro } from '@/components/widgets/MotionSectionIntro';
import { education } from '@/data/education';
import { experience } from '@/data/experience';
---

<section id='experience' class='py-(--space-section-y) px-(--section-padding-x)' aria-labelledby='experience-heading'>
  <div class='mx-auto w-full max-w-(--section-max)'>
    <MotionSectionIntro client:visible>
      <header class='mb-(--space-section-header)'>
        <h2 id='experience-heading' class='scroll-anchor type-section-title m-0 text-balance'>Experience</h2>
      </header>
    </MotionSectionIntro>

    <MotionExperienceList client:visible experience={experience} education={education} />
  </div>
</section>
