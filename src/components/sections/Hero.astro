---
import { getImage } from 'astro:assets';

import { hero } from '@/data/bio';
import heroImage from '@/assets/images/hero-blue-abstract.png';

const heroImageOptions = {
  src: heroImage,
  layout: 'full-width' as const,
  fit: 'cover' as const,
};

const [heroAvif, heroWebp, heroLqip, heroSrc] = await Promise.all([
  getImage({ ...heroImageOptions, format: 'avif' }),
  getImage({ ...heroImageOptions, format: 'webp' }),
  getImage({ ...heroImageOptions, format: 'webp', width: 128 }),
  getImage({ ...heroImageOptions, format: 'webp', width: 640 }),
]);

const { width, height } = heroWebp.attributes;

const headlineWordsByLine = hero.headlineLines.map((line, lineIndex) => {
  const offset = hero.headlineLines.slice(0, lineIndex).reduce((sum, entry) => sum + entry.split(' ').length, 0);

  return line.split(' ').map((word, wordIndex) => ({
    word,
    enterIndex: offset + wordIndex + 1,
  }));
});

const leadEnterIndex = headlineWordsByLine.flat().length + 1;
---

<div class='hero-scroll-track'>
  <section id='hero' class='hero-shell' aria-labelledby='hero-heading'>
    <link
      rel='preload'
      as='image'
      imagesrcset={heroAvif.srcSet.attribute}
      imagesizes='100vw'
      type='image/avif'
      fetchpriority='high'
    />

    <div class='hero-panel relative isolate overflow-hidden'>
      <div class='hero-panel__media absolute inset-0'>
        <div class='hero-panel__lqip' style={`background-image: url(${heroLqip.src})`} aria-hidden='true'></div>
        <picture class='hero-panel__picture'>
          <source srcset={heroAvif.srcSet.attribute} sizes='100vw' type='image/avif' />
          <source srcset={heroWebp.srcSet.attribute} sizes='100vw' type='image/webp' />
          <img
            width={width}
            height={height}
            src={heroSrc.src}
            srcset={heroWebp.srcSet.attribute}
            sizes='100vw'
            alt={hero.imageAlt}
            loading='eager'
            decoding='async'
            fetchpriority='high'
            class='hero-panel__image'
            data-hero-image
          />
        </picture>
        <div
          class='hero-panel__scrim pointer-events-none absolute inset-0 z-[1] bg-linear-to-b from-black/55 via-black/35 to-black/65'
          aria-hidden='true'>
        </div>
      </div>

      <div class='texture-noise-overlay pointer-events-none absolute inset-0 z-[2]' aria-hidden='true'></div>

      <div
        class='hero-panel__content relative z-[3] flex flex-col justify-end px-(--section-padding-x) pb-[clamp(2.5rem,8vw,5rem)] pt-[calc(3rem+env(safe-area-inset-top))]'>
        <div class='mx-auto w-full max-w-(--section-max)'>
          <div class='flex max-w-[56rem] flex-col gap-5'>
            <h1
              id='hero-heading'
              class='type-display m-0 max-w-[30ch] text-(length:--text-display-hero) leading-[1.02] font-semibold tracking-[-0.035em] text-hero-text'>
              {
                headlineWordsByLine.map(words => (
                  <span class='block'>
                    {words.map(({ word, enterIndex }, wordIndex) => (
                      <>
                        {wordIndex > 0 ? ' ' : ''}
                        <span class='hero-enter hero-enter--word inline-block' style={`--hero-enter-i: ${enterIndex}`}>
                          {word}
                        </span>
                      </>
                    ))}
                  </span>
                ))
              }
            </h1>
            <p
              class='hero-enter hero-enter--lead type-display m-0 max-w-[38ch] text-(length:--text-display-lead) leading-[1.55] text-pretty text-hero-text-muted'
              style={`--hero-enter-i: ${leadEnterIndex}`}>
              {hero.lead}
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>
</div>

<script>
  const heroTrack = document.querySelector('.hero-scroll-track');
  const heroShell = document.getElementById('hero');
  const heroImage = document.querySelector('[data-hero-image]');
  const scrollRange = 140;

  const easeOut = (value: number) => 1 - Math.pow(1 - value, 2);

  if (heroTrack instanceof HTMLElement && heroShell) {
    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    let ticking = false;
    let lastProgress = reduceMotion ? 1 : -1;

    heroTrack.style.setProperty('--hero-scroll-range', `${scrollRange}px`);

    if (reduceMotion) {
      heroTrack.dataset.motion = 'reduce';
    }

    const readTokens = () => {
      const rootStyles = getComputedStyle(document.documentElement);

      heroShell.style.setProperty('--hero-inset-x-px', rootStyles.getPropertyValue('--hero-inset-x'));
      heroShell.style.setProperty('--hero-inset-y-px', rootStyles.getPropertyValue('--hero-inset-y'));
      heroShell.style.setProperty('--hero-radius-px', rootStyles.getPropertyValue('--radius-hero'));
    };

    const syncScroll = () => {
      if (!reduceMotion && lastProgress >= 1 && window.scrollY / scrollRange >= 1) {
        return;
      }

      const progress = reduceMotion ? 1 : easeOut(Math.min(1, window.scrollY / scrollRange));

      if (progress === lastProgress) {
        return;
      }

      lastProgress = progress;
      heroShell.style.setProperty('--hero-progress', String(progress));
      heroTrack.dataset.settled = progress >= 1 ? 'true' : 'false';
    };

    const onScroll = () => {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(() => {
        syncScroll();
        ticking = false;
      });
    };

    readTokens();
    syncScroll();

    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener(
      'resize',
      () => {
        readTokens();
        syncScroll();
      },
      { passive: true },
    );
  }

  if (heroImage instanceof HTMLImageElement) {
    const media = heroImage.closest('.hero-panel__media');

    const reveal = () => {
      heroImage.classList.add('is-loaded');
      media?.classList.add('is-loaded');
    };

    if (heroImage.complete) {
      reveal();
    } else {
      heroImage.addEventListener('load', reveal, { once: true });
    }
  }
</script>

<style>
  .hero-scroll-track {
    --hero-scroll-range: 140px;
    height: calc(100svh + var(--hero-scroll-range));
  }

  .hero-scroll-track[data-motion='reduce'] {
    height: auto;
  }

  .hero-shell {
    --hero-progress: 0;
    --hero-inset-x-px: 0px;
    --hero-inset-y-px: 0px;
    --hero-radius-px: 0px;
    position: sticky;
    top: 0;
    min-height: 100svh;
    padding-inline: calc(var(--hero-inset-x-px) * var(--hero-progress));
    padding-block: calc(var(--hero-inset-y-px) * var(--hero-progress));
  }

  .hero-scroll-track[data-motion='reduce'] .hero-shell {
    position: static;
    min-height: 0;
  }

  @supports (height: 100dvh) {
    .hero-scroll-track {
      height: calc(100dvh + var(--hero-scroll-range));
    }

    .hero-shell {
      min-height: 100dvh;
    }
  }

  .hero-panel {
    contain: layout paint;
    min-height: calc(100svh - (var(--hero-inset-y-px) * var(--hero-progress) * 2));
    border-radius: calc(var(--hero-radius-px) * var(--hero-progress));
    box-shadow:
      0 0 0 1px oklch(0 0 0 / calc(0.06 * var(--hero-progress))),
      0 1px 2px -1px oklch(0 0 0 / calc(0.06 * var(--hero-progress))),
      0 2px 4px 0 oklch(0 0 0 / calc(0.04 * var(--hero-progress)));
  }

  .hero-panel__content {
    min-height: calc(100svh - (var(--hero-inset-y-px) * var(--hero-progress) * 2));
  }

  @supports (height: 100dvh) {
    .hero-panel,
    .hero-panel__content {
      min-height: calc(100dvh - (var(--hero-inset-y-px) * var(--hero-progress) * 2));
    }
  }

  @keyframes hero-enter-header {
    from {
      opacity: 0;
      transform: translateY(-6px);
    }

    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes hero-enter-content {
    from {
      opacity: 0;
      transform: translateY(8px);
      filter: blur(5px);
    }

    to {
      opacity: 1;
      transform: translateY(0);
      filter: blur(0);
    }
  }

  .hero-enter {
    opacity: 0;
    animation: hero-enter-content var(--hero-enter-duration) var(--hero-enter-ease) forwards;
  }

  .hero-enter--header {
    transform-origin: top left;
    animation-name: hero-enter-header;
    animation-timing-function: var(--ease-out);
    animation-delay: 0ms;
  }

  .hero-enter--word,
  .hero-enter--lead {
    transform-origin: left bottom;
    animation-delay: calc(var(--hero-enter-i) * var(--hero-enter-stagger));
  }

  .hero-panel__media {
    background-color: oklch(0.311 0.049 245.613);
    transform: translateZ(0);
  }

  .hero-panel__lqip {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    transform: scale(1.06);
    filter: blur(24px);
    transition: opacity var(--hero-media-duration) var(--hero-enter-ease);
  }

  .hero-panel__media.is-loaded .hero-panel__lqip {
    opacity: 0;
  }

  .hero-panel__picture {
    position: absolute;
    inset: 0;
    display: block;
  }

  .hero-panel__image {
    width: 100%;
    height: 100%;
    max-width: none;
    object-fit: cover;
    object-position: center;
    opacity: 0;
    transition: opacity var(--hero-media-duration) var(--hero-enter-ease);
    outline: 1px solid oklch(1 0 0 / 0.1);
    outline-offset: -1px;
  }

  .hero-panel__image.is-loaded {
    opacity: 1;
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-scroll-track {
      height: auto;
    }

    .hero-shell {
      --hero-progress: 1;
      position: static;
      min-height: 0;
    }

    .hero-enter {
      opacity: 1;
      transform: none;
      filter: none;
      animation: none;
    }

    .hero-panel__lqip {
      filter: blur(12px);
      transition: none;
    }

    .hero-panel__media.is-loaded .hero-panel__lqip {
      opacity: 0;
    }

    .hero-panel__image {
      opacity: 1;
      transition: none;
    }
  }
</style>
