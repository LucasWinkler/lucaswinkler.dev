---
import { getImage } from 'astro:assets';
import Header from '@/components/common/Header.astro';
import { hero } from '@/data/bio';
import heroImage from '@/assets/images/hero-blue-abstract.png';

const heroImageOptions = {
  src: heroImage,
  layout: 'full-width' as const,
  fit: 'cover' as const,
};

const [heroAvif, heroWebp, heroLqip, heroSrc] = await Promise.all([
  getImage({ ...heroImageOptions, format: 'avif' }),
  getImage({ ...heroImageOptions, format: 'webp' }),
  getImage({ ...heroImageOptions, format: 'webp', width: 128 }),
  getImage({ ...heroImageOptions, format: 'webp', width: 640 }),
]);

const { width, height } = heroWebp.attributes;
---

<section
  id="hero"
  class="hero-shell px-(--hero-inset-x) pt-(--hero-inset-y) pb-(--hero-inset-y)"
  aria-labelledby="hero-heading"
>
  <link
    rel="preload"
    as="image"
    imagesrcset={heroAvif.srcSet.attribute}
    imagesizes="100vw"
    type="image/avif"
    fetchpriority="high"
  />

  <div class="hero-panel relative isolate min-h-(--hero-panel-min-h) overflow-hidden rounded-(--radius-hero)">
    <div class="hero-panel__media absolute inset-0">
      <div
        class="hero-panel__lqip"
        style={`background-image: url(${heroLqip.src})`}
        aria-hidden="true"
      />
      <picture class="hero-panel__picture">
        <source
          srcset={heroAvif.srcSet.attribute}
          sizes="100vw"
          type="image/avif"
        />
        <source
          srcset={heroWebp.srcSet.attribute}
          sizes="100vw"
          type="image/webp"
        />
        <img
          width={width}
          height={height}
          src={heroSrc.src}
          srcset={heroWebp.srcSet.attribute}
          sizes="100vw"
          alt={hero.imageAlt}
          loading="eager"
          decoding="async"
          fetchpriority="high"
          class="hero-panel__image"
          data-hero-image
        />
      </picture>
      <div
        class="hero-panel__scrim pointer-events-none absolute inset-0 z-[1] bg-linear-to-b from-black/55 via-black/35 to-black/65"
        aria-hidden="true"
      />
    </div>

    <div
      class="texture-noise-overlay pointer-events-none absolute inset-0 z-[2]"
      aria-hidden="true"
    />

    <Header />

    <div class="hero-panel__content relative z-[3] flex min-h-(--hero-panel-min-h) flex-col justify-end px-(--section-padding-x) pb-[clamp(2.5rem,8vw,5rem)] pt-[calc(3rem+env(safe-area-inset-top))]">
      <div class="mx-auto w-full max-w-(--section-max)">
        <div class="flex max-w-[56rem] flex-col gap-5">
          <h1
            id="hero-heading"
            class="type-display m-0 max-w-[30ch] text-(length:--text-display-hero) leading-[1.02] font-semibold tracking-[-0.035em] text-balance text-hero-text"
          >
            {hero.headline}
          </h1>
          <p
            class="type-display m-0 max-w-[38ch] text-(length:--text-display-lead) leading-[1.55] text-pretty text-hero-text-muted"
          >
            {hero.lead}
          </p>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const heroImage = document.querySelector('[data-hero-image]');

  if (heroImage instanceof HTMLImageElement) {
    const media = heroImage.closest('.hero-panel__media');

    const reveal = () => {
      heroImage.classList.add('is-loaded');
      media?.classList.add('is-loaded');
    };

    if (heroImage.complete) {
      reveal();
    } else {
      heroImage.addEventListener('load', reveal, { once: true });
    }
  }
</script>

<style>
  .hero-panel__media {
    background-color: #1a3348;
  }

  .hero-panel__lqip {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    transform: scale(1.06);
    filter: blur(24px);
    transition: opacity 520ms var(--ease-out);
  }

  .hero-panel__media.is-loaded .hero-panel__lqip {
    opacity: 0;
  }

  .hero-panel__picture {
    position: absolute;
    inset: 0;
    display: block;
  }

  .hero-panel__image {
    width: 100%;
    height: 100%;
    max-width: none;
    object-fit: cover;
    object-position: center;
    opacity: 0;
    transition: opacity 520ms var(--ease-out);
    outline: 1px solid rgba(255, 255, 255, 0.08);
    outline-offset: -1px;
  }

  .hero-panel__image.is-loaded {
    opacity: 1;
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-panel__lqip {
      filter: blur(12px);
      transition: none;
    }

    .hero-panel__media.is-loaded .hero-panel__lqip {
      opacity: 0;
    }

    .hero-panel__image {
      opacity: 1;
      transition: none;
    }
  }
</style>
