---
import '../hero/hero.css';
import './error-hero.css';

import { getImage } from 'astro:assets';

import HeaderHero from '@/components/common/header/HeaderHero.astro';
import heroImage from '@/assets/images/hero-blue-abstract.png';

const heroImageOptions = {
  src: heroImage,
  layout: 'full-width' as const,
  fit: 'cover' as const,
};

const [heroAvif, heroWebp, heroLqip, heroSrc] = await Promise.all([
  getImage({ ...heroImageOptions, format: 'avif' }),
  getImage({ ...heroImageOptions, format: 'webp' }),
  getImage({ ...heroImageOptions, format: 'webp', width: 128 }),
  getImage({ ...heroImageOptions, format: 'webp', width: 960 }),
]);

const { width, height } = heroWebp.attributes;
---

<section class='error-hero-shell' aria-labelledby='error-heading'>
  <link
    rel='preload'
    as='image'
    imagesrcset={heroAvif.srcSet.attribute}
    imagesizes='100vw'
    type='image/avif'
    fetchpriority='high'
  />

  <div class='error-hero-panel relative isolate overflow-hidden'>
    <HeaderHero brandHref='/' />

    <div class='hero-panel__media hero-panel__media--muted absolute inset-0' aria-hidden='true'>
      <div
        class='hero-panel__lqip hero-panel__lqip--muted'
        style={`background-image: url(${heroLqip.src})`}
        aria-hidden='true'>
      </div>
      <picture class='hero-panel__picture'>
        <source srcset={heroAvif.srcSet.attribute} sizes='100vw' type='image/avif' />
        <source srcset={heroWebp.srcSet.attribute} sizes='100vw' type='image/webp' />
        <img
          width={width}
          height={height}
          src={heroSrc.src}
          srcset={heroWebp.srcSet.attribute}
          sizes='100vw'
          alt=''
          loading='eager'
          decoding='async'
          fetchpriority='high'
          class='hero-panel__image hero-panel__image--muted'
          data-hero-image
        />
      </picture>
      <div class='error-hero-panel__scrim pointer-events-none absolute inset-0 z-[1]'></div>
    </div>

    <div class='texture-noise-overlay pointer-events-none absolute inset-0 z-[2]' aria-hidden='true'></div>

    <div class='error-hero-panel__content relative z-[3] flex flex-col justify-end px-(--section-padding-x)'>
      <div class='section-inner flex flex-col gap-6'>
        <p class='error-hero__display type-display tabular-nums' aria-hidden='true'>404</p>

        <div class='flex flex-col gap-4'>
          <h1
            id='error-heading'
            tabindex='-1'
            class='scroll-anchor type-section-title error-hero__headline m-0 text-balance'>
            <span class='sr-only'>Page not found.</span>
            This page isn&apos;t one of them.
          </h1>
          <p class='type-section-lead error-hero__lead m-0 text-pretty'>
            The link might be broken, outdated, or mistyped. Head home to see the work that actually shipped.
          </p>
        </div>

        <div class='error-hero__actions'>
          <a href='/' class='error-hero__cta type-nav touch-manipulation select-none cursor-pointer'>
            Back to homepage
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
